:8080 {
	handle /rpc/* {
		reverse_proxy localhost:4003 {
			flush_interval -1
		}
	}

	handle /health-check {
		reverse_proxy localhost:4003
	}

	handle /logs/* {
		reverse_proxy localhost:4003 {
			flush_interval -1
		}
	}

	handle /cli {
		reverse_proxy localhost:4003 {
			flush_interval -1
		}
	}

	handle /mcp {
		header Access-Control-Allow-Origin *
		header Access-Control-Allow-Methods "GET, POST, OPTIONS, DELETE"
		header Access-Control-Allow-Headers "Content-Type, Accept, Mcp-Session-Id"
		header Access-Control-Expose-Headers "Mcp-Session-Id"

		@options method OPTIONS
		respond @options 204

		reverse_proxy localhost:{$MCP_PORT} {
			flush_interval -1
		}
	}

	handle_path /console/* {
		root * /workspace/console-app
		try_files {path} /index.html
		file_server
	}

	handle {
		root * /workspace/project/app/dist
		try_files {path} /index.html
		file_server
	}
}
